# TriviaVerse Configuration
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-super-secret-key-change-this
API_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=sqlite:///triviaverse.db
# For production:
# DATABASE_URL=mysql://user:password@localhost:3306/triviaverse
# DATABASE_URL=postgresql://user:password@localhost:5432/triviaverse

# Mail (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_LEADERBOARD_WEBHOOK=your-discord-webhook-url

# Socket.IO
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ALLOWED_ORIGINS=*
CORS_ORIGINS=*

# OpenAI (for AI-generated questions)
OPENAI_API_KEY=your-openai-api-key

# Owner Configuration
OWNER_USERNAME=admin
# OWNER_DISCORD_ID=your-discord-id
# OWNER_EMAIL=admin@example.com

# Economy
WIN_REWARD_COINS=100
PERFECT_GAME_BONUS=200

# Rate Limiting
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_STORAGE_URL=memory://

# Optional: Elasticsearch
# ELASTICSEARCH_URL=http://localhost:9200

# Optional: Gunicorn
GUNICORN_WORKERS=4
GUNICORN_BIND=0.0.0.0:5000
